{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"]
  },
  "include": [
    "entrypoints/**/*",
    "lib/**/*",
    "tests/**/*",
    "wxt.config.ts",
    "tailwind.config.ts",
    ".wxt/types/**/*"
  ],
  "exclude": ["node_modules", ".output"]
}
